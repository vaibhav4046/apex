# apex — pick at least one LLM provider (free)

# Groq — https://console.groq.com (fast, free)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras — https://cloud.cerebras.ai (1M tokens/day free)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# Ollama (local, no key) — install from https://ollama.com
# ollama pull llama3.1:8b
OLLAMA_ENABLED=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# Override data dir (default: ~/.apex)
# APEX_DATA_DIR=
