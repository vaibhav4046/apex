{
  "name": "apex-cli",
  "version": "0.1.0",
  "description": "Autonomous job application CLI — generates tailored resume + cover letter, applies on LinkedIn/Indeed/Wellfound. Free LLMs.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "apex": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node20 --clean --shims",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^0.2.14",
    "@clack/prompts": "^0.7.0",
    "ai": "^4.3.16",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "kleur": "^4.1.5",
    "marked": "^14.1.4",
    "ora": "^8.1.1",
    "playwright": "^1.49.1",
    "puppeteer": "^23.10.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
